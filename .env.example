# YooKassa webhook: для локальной разработки установить YOOKASSA_WEBHOOK_IP_CHECK=false
# YOOKASSA_WEBHOOK_IP_CHECK=

# Cloudflare Turnstile (логин с капчей после N неудачных попыток)
# Создать виджет: https://dash.cloudflare.com → Turnstile → Add widget
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Web Push (PWA уведомления)
# Сгенерировать ключи: npx web-push generate-vapid-keys
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@example.com
